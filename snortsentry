#!/usr/bin/perl -T
#
# snortsentry v8.1.7 - Snort/PF blocker for OpenBSD
#
# Configuration precedence is now CLI > Config File > Default.
# FIXED: All CLI options are now defined in parse_pre_config_options to prevent 'Unknown option' error.
# FIXED: The show_help subroutine was missing a closing brace.
# FIXED: %alert_parsers is now declared 'our' to prevent 'will not stay shared' warning.
# FIXED: CLI arguments are now saved before the first parser and re-fed to the second parser
#        to correctly honor the -D/--no-daemon flag and prevent unintended daemonization.
# FIXED: IPv4-mapped IPv6 address rewriting (::ffff:x.x.x.x -> x.x.x.x) now works correctly
#        with NetAddr::IP v3.x using pure regex against the canonical addr string.
#        RewriteMappedIPv4 is enabled by default. No NetAddr::IP v4.x dependency required.

use strict ;
use warnings ;
use Getopt::Long ;
use POSIX
  qw(setsid strftime SIG_BLOCK SIG_UNBLOCK SIGHUP SIGINT SIGTERM) ;
use File::Basename ;
use File::Temp qw(tempfile) ;
use File::Spec ;
use Sys::Syslog qw(:standard :macros) ;
use Fcntl       qw(:flock) ;
use Digest::SHA qw(sha256_hex) ;
use POSIX       qw(:signal_h) ;
use Socket      qw(AF_INET AF_INET6) ;

# Clean environment for taint mode
delete @ENV{qw(IFS CDPATH ENV BASH_ENV PATH LOAD_LIBRARY)} ;
$ENV{PATH} =
  '/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin' ;

# Required modules
# NetAddr::IP::Util and newer functions are avoided for compatibility with v3.x.
foreach my $mod ( qw(NetAddr::IP JSON File::Temp) )
{
    eval "require $mod; $mod->import(); 1"
      or die "ERROR: Module $mod required\n" ;
    }

our $VERSION = '8.1.7' ;

# Default configuration with sensible defaults
my %config = (config_file            => '/etc/snort/snortsentry.conf',
              alert_file             => '/var/log/snort/alert',
              pid_file               => '/var/run/snortsentry.pid',
              lock_file              => '/var/run/snortsentry.lock',
              state_file             => '/var/db/snortsentry.state',
              log_file               => undef,
              block_duration         => 60,
              max_block_duration     => 86400,
              priority               => 1,
              keywords               => [],
              whitelist              => [],
              pf_table               => 'snort_block',
              pf_anchor              => 'snort_block',
              use_anchor             => 1,
              daemon                 => 1,
              log_level              => 'info',
              and_prio_key           => 1,
              check_interval         => 1,
              batch_interval         => 5,
              max_batch_size         => 100,
              enable_escalation      => 1,
              escalation_tiers       => [ 60, 300, 1800, 3600 ],
              unblock_on_exit        => 0,
              stats_interval         => 300,
              auto_whitelist_rfc1918 => 1,
              dry_run                => 0,
              max_blocks             => 10000,
              alert_format           => 'fast',
              max_pf_retries         => 3,
              rewrite_mapped_ipv4    => 1,
              pf_retry_delay         => 1,
              status_check           => 0,
             ) ;

# Global array to define which keys can be overridden by command line arguments.
my @cli_keys = qw(
  config_file alert_file pid_file lock_file state_file log_file
  pf_table pf_anchor use_anchor
  check_interval batch_interval priority block_duration max_block_duration
  enable_escalation unblock_on_exit max_blocks log_level daemon dry_run
) ;

# Runtime state
my %blocked_ips ;
my %pending_blocks ;
my %failed_blocks ;
my $last_pos        = 0 ;
my $last_inode      = 0 ;
my $running         = 1 ;
my $reload_config   = 0 ;
my $dump_stats      = 0 ;
my $last_batch_time = 0 ;
my $last_stats_time = 0 ;
my @whitelist_cidr ;
my @keywords_regex ;
my $LOCK_FH ;
my $PID_FH ;
my $cli_verbose = 0 ;
my %log_levels  = ( debug => 0, info => 1, warn => 2, error => 3 ) ;

# Declare %alert_parsers as 'our' to satisfy 'use strict' in a global scope
our %alert_parsers = ( fast    => \&parse_fast_alert,
                       unified => \&parse_unified_alert,
                       json    => \&parse_json_alert,
                     ) ;
my %stats = ( alerts_processed => 0,
              ips_blocked      => 0,
              ips_unblocked    => 0,
