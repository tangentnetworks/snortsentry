              whitelisted_hits => 0,
              pf_failures      => 0,
              started_at       => time()
            ) ;

# Signal handlers
$SIG{TERM} = sub {
    my $sigset = POSIX::SigSet->new( SIGTERM(), SIGINT(), SIGHUP() ) ;
    POSIX::sigprocmask( SIG_BLOCK(), $sigset )
      or log_msg( 'error', "sigprocmask failed on TERM: $!" ) ;
    $running = 0 ;
    POSIX::sigprocmask( SIG_UNBLOCK(), $sigset )
      or log_msg( 'error', "sigprocmask failed on TERM unblock: $!" ) ;
      } ;
$SIG{INT} = $SIG{TERM} ;

$SIG{HUP} = sub {
    my $sigset = POSIX::SigSet->new( SIGTERM(), SIGINT(), SIGHUP() ) ;
    POSIX::sigprocmask( SIG_BLOCK(), $sigset )
      or log_msg( 'error', "sigprocmask failed on HUP: $!" ) ;
    $reload_config = 1 ;
    POSIX::sigprocmask( SIG_UNBLOCK(), $sigset )
      or log_msg( 'error', "sigprocmask failed on HUP unblock: $!" ) ;
      } ;

$SIG{USR1} = sub {
    my $sigset = POSIX::SigSet->new( SIGTERM(), SIGINT(), SIGHUP() ) ;
    POSIX::sigprocmask( SIG_BLOCK(), $sigset )
      or log_msg( 'error', "sigprocmask failed on USR1: $!" ) ;
    $dump_stats = 1 ;
    POSIX::sigprocmask( SIG_UNBLOCK(), $sigset )
      or log_msg( 'error', "sigprocmask failed on USR1 unblock: $!" ) ;
      } ;

sub main
{
    # Store a copy of the initial default configuration settings.
    my %initial_config = %config ;

    # Save the original command line arguments for the second parsing pass.
    # The first parser will consume flags, making them disappear from @ARGV.
    my @original_argv = @ARGV ;

    # Parse only the command-line options necessary to find the config file,
    # and handle immediate exit options.
    my %cli_temp ;
    parse_pre_config_options( \%cli_temp ) ;

    # Handle immediate exit flags using the default/CLI config path
    if ( $cli_temp{version} )
    {
        print "snortsentry v$VERSION\n" ;
        exit 0 ;
        }
    if ( $cli_temp{help} )
    {
        show_help() ;
        exit 0 ;
        }

    # Check for status flag consumed in the first pass
    if ( $cli_temp{status} )
    {
        $config{status_check} = 1 ;
        }

    # Apply the CLI-specified config file path (if provided)
    if ( $cli_temp{config_file} )
    {
        $config{config_file} = $cli_temp{config_file} ;
        }

    # Load the configuration file (applies Config File > Default)
    load_config() ;

    # Parse ALL remaining CLI options and capture values that override the config file
    # Pass the original arguments to the post-config parser
    my %cli_final_overrides =
      parse_post_config_options( \%initial_config, \@original_argv ) ;

    # Re-apply CLI settings (CLI > Config File)
    foreach my $key ( keys %cli_final_overrides )
    {
        $config{$key} = $cli_final_overrides{$key} ;
        }

    # Handle the verbose flag, giving it the highest precedence.
    if ( $cli_verbose )
    {
        $config{log_level} = 'debug' ;
        }

    # Untaint ALL CLI-derived file paths (Required for -T mode)
    # The variables are safe if they contain only standard path characters.
    foreach my $file_key (
                 qw(alert_file pid_file lock_file state_file log_file) )
    {
        if ( defined $config{$file_key} )
        {
            my $path = $config{$file_key} ;

        # Check for alphanumeric, dashes, underscores, dots, and slashes
            if ( $path =~ m{^([a-zA-Z0-9_\-\./]+)$} )
            {
                $config{$file_key} =
                  $1 ;
                }
            else
            {
                die
"Insecure path detected for $file_key (Taint Mode): $path\n"
                  ;
                }
            }
        }

    # HANDLE STATUS CHECK HERE, AFTER CONFIG IS FULLY LOADED
    if ( $config{status_check} )
    {
        show_status() ;
        exit 0 ;
        }

    validate_config() ;
    parse_whitelist() ;
    preprocess_keywords() ;

    # Validate and Initialize Configuratio
    daemonize() if $config{daemon} ;
    acquire_lock() ;
    write_pid() ;

    if ( $config{daemon} )
    {
        setup_syslog() ;
        }
    else
    {
        log_msg( 'info', "Running in foreground mode" ) ;
        }

    log_msg( 'info', "snortsentry v$VERSION started (PID $$)" ) ;

    # IPv4-mapped IPv6 rewrite uses pure regex against the canonical addr
    # string returned by NetAddr::IP->new()->addr, which is stable across
    # all NetAddr::IP versions including v3.x. No v4.x methods are called.
    log_msg( 'debug',
"IPv4-mapped IPv6 rewrite: active (pure-regex, no NetAddr::IP v4.x required)"
    ) ;

    # Log based on anchor usage
    if ( $config{use_anchor} )
    {
        log_msg(
            'info',
"Using PF anchor: $config{pf_anchor}, table: $config{pf_table}"
        ) ;
        }
    else
    {
        log_msg(
              'info',
              "Using PF table only: $config{pf_table} (Anchor disabled)"
        ) ;
        log_msg(
            'warn',
"Table-Only Mode requires manual configuration of the blocking rule in /etc/pf.conf"
        ) ;
        }

    setup_pf_anchor()
      ;

    if ( $config{dry_run} )
    {
        log_msg( 'warn', "DRY RUN: PF will not be modified" ) ;
        }

    load_state() ;
    initialize_alert_tracking() ;

    # Main loop
    while ( $running )
    {
        my $now = time() ;

        process_alerts() ;

        if ( $now - $last_batch_time >= $config{batch_interval} )
        {
            apply_pending_blocks() ;
            cleanup_expired() ;
            $last_batch_time = $now ;
            }

        if ( keys %pending_blocks >= $config{max_batch_size} )
        {
            apply_pending_blocks() ;
            $last_batch_time = $now ;
            }

        if ( $now - $last_stats_time >= $config{stats_interval} )
        {
            log_statistics() ;
            $last_stats_time = $now ;
            }

        if ( $config{state_file} && ( $now % 60 ) == 0 )
        {
            save_state() ;
            }

        if ( $reload_config )
        {
            reload_config_safe() ;
            $reload_config = 0 ;
            }

        if ( $dump_stats )
        {
            dump_statistics() ;
            $dump_stats = 0 ;
            }

        sleep $config{check_interval} ;
        }

    cleanup() ;
    log_msg( 'info', "snortsentry stopped" ) ;
    exit 0 ;
    }

# Parse only the critical options needed to find the config file
# and check for immediate exit flags (version/help/status).
sub parse_pre_config_options
{
    my ( $cli_temp ) = @_ ;

# Define throw-away variables to satisfy Getopt::Long that the options are known.
    my $tmp_a ;
    my $tmp_p ;
    my $tmp_l ;
    my $tmp_s ;
    my $tmp_log ;
    my $tmp_t ;
    my $tmp_v ;
    my $tmp_D ;
    my $tmp_n ;

    # Explicitly look for the config file, help, version, and status.
    # The other options are listed to prevent 'Unknown option' error but are ignored.
    GetOptions(
        'f|config=s' => \$cli_temp->{config_file},
        'a|alert=s'   => \$tmp_a,
        'p|pid=s'     => \$tmp_p,
        'l|lock=s'    => \$tmp_l,
        's|state=s'   => \$tmp_s,
        'log=s'       => \$tmp_log,
        't|table=s'   => \$tmp_t,
        'v|verbose'   => \$tmp_v,
        'D|no-daemon' => \$tmp_D,
        'n|dry-run'   => \$tmp_n,
        'h|help'      => sub { $cli_temp->{help}    = 1 ; },
        'version'     => sub { $cli_temp->{version} = 1 ; },
        'status'      => sub { $cli_temp->{status}  = 1 ; },
              )
      or die "Error parsing options. Use -h for help.\n" ;
    }

# NEW SUBROUTINE: Parse ALL command line options after the config file has been loaded.
# This captures only the values that were explicitly set to override the config file.
sub parse_post_config_options
{
    my ( $initial_config, $args_ref ) = @_ ;
    my %cli_overrides = () ;

    # Restore @ARGV for this second parsing phase so all arguments are seen.
    # Use 'local' to ensure @ARGV is restored after this subroutine exits.
    local @ARGV = @$args_ref ;

    # Use temporary variables here, which are then checked to see if the user specified them.
    my $cli_alert_file ;
    my $cli_pid_file ;
    my $cli_lock_file ;
    my $cli_state_file ;
    my $cli_log_file ;
    my $cli_pf_table ;
    my $cli_daemon_off ;
    my $cli_dry_run ;

  # Explicitly list the options again, pointing to the temporary
  # variables or the global state for flags like -v.
    GetOptions(
        'f|config=s' => \
          my $cli_config_file,
        'a|alert=s'   => \$cli_alert_file,
        'p|pid=s'     => \$cli_pid_file,
        'l|lock=s'    => \$cli_lock_file,
        's|state=s'   => \$cli_state_file,
        'log=s'       => \$cli_log_file,
        't|table=s'   => \$cli_pf_table,
        'v|verbose'   => \$cli_verbose,
        'D|no-daemon' => \$cli_daemon_off,
        'n|dry-run'   => \$cli_dry_run,
        'h|help'      => sub { },
        'version'     => sub { },
        'status'      => sub { },
              )
      or die "Error parsing options. Use -h for help.\n" ;

    # Now check if the temporary variables were actually set by the user
    $cli_overrides{alert_file} = $cli_alert_file
      if defined $cli_alert_file ;
    $cli_overrides{pid_file}  = $cli_pid_file if defined $cli_pid_file ;
    $cli_overrides{lock_file} = $cli_lock_file
      if defined $cli_lock_file ;
    $cli_overrides{state_file} = $cli_state_file
      if defined $cli_state_file ;
    $cli_overrides{log_file} = $cli_log_file if defined $cli_log_file ;
    $cli_overrides{pf_table} = $cli_pf_table if defined $cli_pf_table ;

    # Handle boolean flags that invert the default:
    if ( defined $cli_daemon_off )
    {
        $cli_overrides{daemon} =
          0 ;  # This is correctly set if -D was seen
        }
    if ( defined $cli_dry_run )
    {
        $cli_overrides{dry_run} = 1 ;
        }

  # Return the hash of only the overridden values
  return %cli_overrides ;
    }

sub load_config
{
  return unless $config{config_file} && -f $config{config_file} ;

    open my $cfh, '<', $config{config_file}
      or die "Cannot open config file: $!" ;
    my $lineno = 0 ;

    # Reset keywords array to allow HUP to fully reload
    $config{keywords} = [] ;

    while ( my $line = <$cfh> )
    {
        $lineno++ ;
        chomp $line ;
        $line =~ s/#.*$// ;
        $line =~ s/^\s+|\s+$//g ;
      next unless length $line ;

        if ( $line =~ /^AlertFile\s+(.+)$/i )
        {
            $config{alert_file} = $1 ;
            }
        elsif ( $line =~ /^PidFile\s+(.+)$/i )
        {
            $config{pid_file} = $1 ;
            }
        elsif ( $line =~ /^LockFile\s+(.+)$/i )
        {
            $config{lock_file} = $1 ;
            }
        elsif ( $line =~ /^StateFile\s+(.+)$/i )
        {
            $config{state_file} = $1 ;
            }
        elsif ( $line =~ /^LogFile\s+(.+)$/i )
        {
            $config{log_file} = $1 ;
            }
        elsif ( $line =~ /^BlockDuration\s+(\d+)$/i )
        {
            $config{block_duration} = $1 ;
            }
        elsif ( $line =~ /^MaxBlockDuration\s+(\d+)$/i )
        {
            $config{max_block_duration} = $1 ;
            }
        elsif ( $line =~ /^PfTable\s+(.+)$/i )
        {
            $config{pf_table} = $1 ;
            }
        elsif ( $line =~ /^PfAnchor\s+(.+)$/i )
        {
            $config{pf_anchor} = $1 ;
            }  # NEW
        elsif ( $line =~ /^UseAnchor\s+(yes|no|true|false|1|0)$/i )
        {
            $config{use_anchor} = parse_bool( $1 ) ;
            }  # NEW
        elsif ( $line =~ /^Priority\s+(\d+)$/i )
        {
            $config{priority} = $1 ;
            }
        elsif ( $line =~ /^LogLevel\s+(debug|info|warn|error)$/i )
        {
            $config{log_level} = lc $1 ;
            }
        elsif ( $line =~ /^CheckInterval\s+(\d+)$/i )
        {
            $config{check_interval} = $1 ;
            }
        elsif ( $line =~ /^BatchInterval\s+(\d+)$/i )
        {
            $config{batch_interval} = $1 ;
            }
        elsif (
              $line =~ /^EnableEscalation\s+(yes|no|true|false|1|0)$/i )
        {
            $config{enable_escalation} = parse_bool( $1 ) ;
            }
        elsif ( $line =~ /^EscalationTiers\s+(.+)$/i )
        {
            my @t = split( /[,\s]+/, $1 ) ;
            $config{escalation_tiers} = \@t ;
            }
        elsif ( $line =~ /^UnblockOnExit\s+(yes|no|true|false|1|0)$/i )
        {
            $config{unblock_on_exit} = parse_bool( $1 ) ;
            }
        elsif ( $line =~ /^StatsInterval\s+(\d+)$/i )
        {
            $config{stats_interval} = $1 ;
            }
        elsif ( $line =~
                /^AutoWhitelistRFC1918\s+(yes|no|true|false|1|0)$/i )
        {
            $config{auto_whitelist_rfc1918} = parse_bool( $1 ) ;
            }
        elsif ( $line =~ /^MaxBlocks\s+(\d+)$/i )
        {
            $config{max_blocks} = $1 ;
            }

        # REVISED: Keyword is now a regex pattern string
        elsif ( $line =~ /^Keyword\s+"([^"]+)"(?:\s+(.*))?$/i )
        {
            my ( $keyword, $rest ) = ( $1, $2 ) ;
            push @{ $config{keywords} }, $keyword ;

            if ( defined $rest )
            {

                # Process whitelist exclusions (e.g., !192.168.1.1)
                while ( $rest =~ /(![\d\.:\/]+)/g )
                {
                    my $excluded = $1 ;
                    $excluded =~ s/^!// ;
                    if ( $excluded =~ /^[\d\.:\/]+$/ )
                    {
                        push @{ $config{whitelist} }, $excluded ;
                        }
                    else
                    {
                        log_msg(
                            'warn',
"invalid whitelist exclusion ignored: !$excluded"
                        ) ;
                        }
                    }
                }
            }
        elsif ( $line =~ /^Whitelist\s+(.+)$/i )
        {
            my @entries = split( /\s+/, $1 ) ;
            foreach my $entry ( @entries )
            {
                if ( $entry =~ /^[\d\.:\/]+$/ )
                {
                    push @{ $config{whitelist} }, $entry ;
                    }
                else
                {
                    log_msg( 'warn',
                             "invalid whitelist entry ignored: $entry"
                           ) ;
                    }
                }
            }
        elsif ( $line =~ /^AlertFormat\s+(fast|unified2|json)$/i )
        {
            $config{alert_format} = lc $1 ;
            }

# RewriteMappedIPv4 rewrites ::ffff:x.x.x.x and ::x.x.x.x addresses to native
# IPv4 before adding to the PF table. Implemented with pure regex against the
# canonical addr string from NetAddr::IP->new()->addr — works correctly with
# NetAddr::IP v3.x and later. Enabled by default.
        elsif (
             $line =~ /^RewriteMappedIPv4\s+(yes|no|true|false|1|0)$/i )
        {
            $config{rewrite_mapped_ipv4} = parse_bool( $1 ) ;
            }
        elsif ( $line =~ /^AndPrioKey\s+(yes|no|true|false|1|0)$/i )
        {
            $config{and_prio_key} = parse_bool( $1 ) ;
            }
        else
        {
            log_msg( 'debug',
                     "Unknown directive at line $lineno: $line" ) ;
            }
        }
    close $cfh ;
    }

sub validate_config
{
    # Verify required files
    foreach my $req ( qw(alert_file pid_file lock_file state_file) )
    {
        unless ( $config{$req} )
        {
            die "Missing required config: $req\n" ;
            }

        my $dir = dirname( $config{$req} ) ;
        unless ( -d $dir )
        {
            log_msg( 'info', "Creating directory $dir for $req" ) ;
            my $mask = umask( 0 ) ;
            mkdir( $dir, 0755 )
              or die "Failed to create directory $dir: $!" ;
            umask( $mask ) ;
            }
        }

    unless ( -f $config{alert_file} )
    {
        die "AlertFile does not exist: $config{alert_file}\n" ;
        }

    # Validate escalation tiers
    if ( $config{enable_escalation} )
    {
        my @tiers = @{ $config{escalation_tiers} } ;
        for my $i ( 1 .. $#tiers )
        {
            die "Escalation tiers must be ascending\n"
              if $tiers[ $i ] <= $tiers[ $i - 1 ] ;
            }
        }
    }

sub parse_bool
{
    my ( $val ) = @_ ;
  return ( $val =~ /^(yes|true|1)$/i ) ? 1 : 0 ;
    }

sub parse_whitelist
{
    @whitelist_cidr = () ;

    if ( $config{auto_whitelist_rfc1918} )
    {
        push @whitelist_cidr, (

            # RFC1918 + loopback/link-local IPv4
            NetAddr::IP->new( '127.0.0.0/8' ),
            NetAddr::IP->new( '10.0.0.0/8' ),
            NetAddr::IP->new( '172.16.0.0/12' ),
            NetAddr::IP->new( '192.168.0.0/16' ),

            # Loopback/link-local/unique-local IPv6
            NetAddr::IP->new( '::1/128' ),
            NetAddr::IP->new( 'fe80::/10' ),
            NetAddr::IP->new( 'fc00::/7' ),
        ) ;
        }

    foreach my $entry ( @{ $config{whitelist} || [] } )
    {
        if ( $entry =~ /^[\d\.:\/]+$/ )
        {
            my $cidr = eval { NetAddr::IP->new( $entry )  } ;
            if ( $cidr )
            {
                push @whitelist_cidr, $cidr ;
                log_msg( 'debug', "whitelist add: $entry" ) ;
                }
            else
            {
                log_msg( 'warn', "invalid whitelist entry: $entry" ) ;
                }
            }
        else
        {
            log_msg( 'warn',
                     "invalid (tainted) whitelist entry ignored: $entry"
                   ) ;
            }
        }
    }

sub preprocess_keywords
{

    # Keywords are now treated as case-insensitive regex patterns
    @keywords_regex = @{ $config{keywords} || [] } ;
    }

sub setup_syslog
{
    openlog( 'snortsentry', 'pid', 'daemon' ) ;
    }

sub log_msg
{
    my ( $level, $msg ) = @_ ;
  return if $log_levels{$level} < $log_levels{ $config{log_level} } ;

    my $ts   = strftime( "%Y-%m-%d %H:%M:%S", localtime() ) ;
    my $line = "[$ts] [$level] $msg" ;

    if ( $config{daemon} )
    {
        syslog(   $level eq 'error' ? LOG_ERR
                : $level eq 'warn'  ? LOG_WARNING
                : $level eq 'info'  ? LOG_INFO
                : LOG_DEBUG,
                "%s",
                $line
              ) ;
        }
    else
    {
        print STDERR "$line\n" ;
        }

    if ( $config{log_file} )
    {
        if ( open my $lf, '>>', $config{log_file} )
        {
            print $lf "$line\n" ;
            close $lf ;
            }
        }
    }

sub initialize_alert_tracking
{
    my @st = stat( $config{alert_file} ) ;
    $last_inode = $st[ 1 ] // 0 ;

    if ( open my $fh, '<', $config{alert_file} )
    {
        if ( $last_pos == 0 )
        {
            seek( $fh, 0, 2 ) ;
            $last_pos   = tell( $fh ) ;
            $last_inode = ( stat( $fh ) )[ 1 ] // 0 ;
            }
        close $fh ;
        }
    }

sub process_alerts
{
  return unless -f $config{alert_file} ;

    my @st            = stat( $config{alert_file} ) ;
    my $current_size  = $st[ 7 ] // 0 ;
    my $current_inode = $st[ 1 ] // 0 ;

    if ( $current_inode != $last_inode )
    {
        log_msg( 'info', "alert file rotated, resetting position" ) ;
        $last_inode = $current_inode ;
        $last_pos   = 0 ;
        }

    if ( $current_size < $last_pos )
    {
        log_msg( 'info',
                 "alert file truncated, resetting position to 0" ) ;
        $last_pos = 0 ;
        }

  return if $current_size <= $last_pos ;

    open my $fh, '<', $config{alert_file} or do
    {
        log_msg( 'error', "open alert: $!" ) ;
      return ;
        } ;

    unless ( seek( $fh, $last_pos, 0 ) )
    {
        log_msg(
            'error',
"seek failed to pos $last_pos: $!, aggressively resetting position"
        ) ;
        close $fh ;
        $last_pos = $current_size ;
      return ;
        }

    my $read_count = 0 ;
    while ( my $line = <$fh> )
    {
        chomp $line ;
        parse_alert( $line ) ;
        $stats{alerts_processed}++ ;
        $read_count++ ;
        }

    $last_pos = tell( $fh ) ;
    close $fh ;

    if ( $read_count > 0 )
    {
        log_msg( 'debug',
                 "read $read_count new lines, last_pos now $last_pos"
               ) ;
        }
    }

sub parse_alert
{
    my ( $line ) = @_ ;
    my $parser =
      $alert_parsers{ $config{alert_format} } || \&parse_fast_alert ;
    $parser->( $line ) ;
    }

